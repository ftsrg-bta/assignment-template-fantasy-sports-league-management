{
  "name": "fantasy-sports",
  "version": "0.1.0",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20",
    "npm": ">=5"
  },
  "scripts": {
    "prestart": "npm run build",
    "start": "fabric-chaincode-node start",
    "prestart:ccaas": "npm run build",
    "start:ccaas": "fabric-chaincode-node server --chaincode-address 0.0.0.0:7052 --chaincode-id \"$CHAINCODE_ID\"",
    "prestart:dev": "npm run build",
    "start:dev": "fabric-chaincode-node start --peer.address \"127.0.0.1:8541\" --chaincode-id-name \"chaincode1:0.0.1\" --tls.enabled false",
    "start:watch": "nodemon --exec \"npm run start:dev\"",
    "start:watch:ccaas": "nodemon --exec \"npm run start:ccaas\"",
    "build": "tsc",
    "build:watch": "tsc -w",
    "prepublishOnly": "npm run build",
    "lint": "eslint . --fix",
    "test": "nyc mocha -r ts-node/register src/**/*.spec.ts"
  },
  "dependencies": {
    "fabric-contract-api": "^2.4.2",
    "fabric-shim": "^2.4.2",
    "json-stringify-deterministic": "^1.0.13",
    "sort-keys-recursive": "^2.1.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/sinon": "^21.0.1",
    "@types/sinon-chai": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "coverage/**",
      "dist/**"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "all": true,
    "check-coverage": true,
    "statements": 100,
    "branches": 100,
    "functions": 100,
    "lines": 100
  }
}
